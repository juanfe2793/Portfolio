{
  "ci": {
    "collect": {
      "staticDistDir": "./build",
      "numberOfRuns": 1,
      "url": ["http://localhost/index.html", "http://localhost/docs/portfolio/cv/index.html"]
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:performance": ["error", { "minScore": 0.95 }]
      }
    }
  }
}
